# Fiverr Monitor Agent Configuration
# Copy this file to .env and fill in your values

# Server URL (Render deployment URL)
SERVER_URL=https://your-app.onrender.com

# Agent Authentication Token (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
AGENT_TOKEN=your_generated_token_here

# Check interval in seconds (how often to check for new messages)
CHECK_INTERVAL=45

# Heartbeat interval in seconds (how often to ping server)
HEARTBEAT_INTERVAL=30

# Reconnect interval in seconds (how long to wait before reconnecting)
RECONNECT_INTERVAL=10

# Chrome debug port (default: 9222)
CHROME_DEBUG_PORT=9222
