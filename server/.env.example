# Fiverr Monitor Server Configuration
# Copy this file to .env and fill in your values

# Agent Authentication Token (must match agent's AGENT_TOKEN)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_TOKEN=your_generated_token_here

# Dashboard Login Credentials
DASHBOARD_USER=admin
DASHBOARD_PASS=your_secure_password_here

# Flask Secret Key (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=your_secret_key_here

# VAPID Keys for Push Notifications
# Generate using the script in README.md
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_CLAIM_EMAIL=mailto:your@email.com

# Port (default: 5000, Render.com uses PORT env var automatically)
PORT=5000
